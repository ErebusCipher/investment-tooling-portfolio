TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
ANTHROPIC_API_KEY=your_anthropic_key

# Comma-separated — get IDs by running discover_groups.py first
# Use @username for public channels, numeric ID for private groups
GROUPS=-1001234567890,-1009876543210,@somePublicChannel

# Minimum message length to bother analysing (default 80 chars)
MIN_LENGTH=80
